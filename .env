# Atlas Portal — default env (commit-safe placeholders).
# Override in `.env.local` (gitignored) for your local dev box.

# Keycloak — 正式 SSO 網域 (2026-06-10 起);本機 dev 容器要用回
# http://localhost:8080/realms/isha 的話放到 .env.local 覆蓋。
# Realm `isha` is what Phase 4-a set up (NOT `atlas`).
VITE_KEYCLOAK_AUTHORITY=https://sso.isafe.org.tw/realms/isha

# OIDC client created in Keycloak Admin Console (realm `isha`):
#   - Clients → Create client
#   - Client type: OpenID Connect
#   - Client ID: atlas-portal
#   - Client authentication: OFF (public client + PKCE)
#   - Standard flow: ON
#   - Valid redirect URIs: http://localhost:5173/*
#   - Valid post logout redirect URIs: http://localhost:5173/*
#   - Web origins: +
VITE_KEYCLOAK_CLIENT_ID=atlas-portal

# atlas-ad API base — JwtBearer-protected endpoints under /api/staged-users etc.
VITE_API_BASE_URL=http://192.168.50.171:5080
