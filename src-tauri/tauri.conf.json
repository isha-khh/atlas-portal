{
  "productName": "atlas-portal",
  "version": "0.1.0",
  "identifier": "tw.org.isha.atlas-portal",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {

      "windows": [
          {
              "title": "Atlas 帳號管理系統",
              "width": 1200,
              "height": 800,
              "resizable": true,
              "devtools": true
          }
      ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
